{
	"name": "gallica-historique-app",
	"version": "1.0.0",
	"description": "gallica historique",
	"type": "module",
	"author": "Valentin Degenne <vdegenne@gmail.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": ""
	},
	"scripts": {
		"dev": "wireit",
		"build": "wireit",
		"build:server": "wireit",
		"build:chrome-extension": "wireit",
		"serve:server": "wireit"
	},
	"wireit": {
		"dev": {
			"dependencies": [
				"build:chrome-extension",
				"dev:vite",
				"serve:server"
			]
		},
		"build": {
			"dependencies": [
				"build:vite",
				"build:server",
				"build:chrome-extension"
			]
		},
		"build:chrome-extension": {
			"command": "rollup -c",
			"files": [
				"./rollup.config.js",
				"./src/chrome-extension/",
				"./src/api.ts",
				"./src/server/api.ts"
			],
			"output": [
				"./chrome-extension/",
				"!./chrome-extension/manifest.json"
			]
		},
		"build:server": {
			"command": "tsc --pretty -p ./tsconfig.server.json",
			"clean": "if-file-deleted",
			"files": [
				"./tsconfig.server.json",
				"./src/server/**/*.ts"
			],
			"output": [
				"./lib/server"
			]
		},
		"serve:server": {
			"service": true,
			"command": "node ./lib/server/server.js",
			"dependencies": [
				"build:server"
			],
			"files": []
		},
		"vuc": {
			"service": true,
			"command": "vuc",
			"files": [
				"./.vuc.json"
			]
		},
		"dev:vite": {
			"service": true,
			"command": "vite --host",
			"dependencies": [
				"vuc"
			]
		},
		"build:vite": {
			"command": "vite build",
			"files": [
				"./vite.config.js",
				"./src/",
				"./index.html",
				"./public"
			],
			"output": [
				"./dist/"
			]
		}
	},
	"devDependencies": {
		"@material/mwc-top-app-bar": "^0.27.0",
		"@material/web": "^2.4.1",
		"@snar/lit": "^1.8.1",
		"@tailwindcss/postcss": "^4.3.0",
		"@types/chrome": "^0.1.42",
		"@vdegenne/about-dialog": "^0.4.2",
		"@vdegenne/debouncer": "^1.0.11",
		"@vdegenne/forms": "^0.1.72",
		"@vdegenne/koa": "^0.1.45",
		"@vdegenne/lit-debug": "^0.1.2",
		"@vdegenne/material-color-helpers": "^1.11.7",
		"@vdegenne/mini-gamepad": "^0.4.16",
		"@vdegenne/mini-rest": "^0.3.2",
		"@vdegenne/rollup": "^0.1.15",
		"@vdegenne/rollup-plugin-minify-html": "^1.0.6",
		"@vdegenne/router": "^0.1.8",
		"@vdegenne/server-helpers": "^0.2.12",
		"custom-element-decorator": "^0.6.0",
		"html-vision": "^0.3.10",
		"lit": "^3.3.2",
		"lit-with-styles": "^2.1.3",
		"material-3-dialog": "^0.1.11",
		"material-shell": "^1.3.10",
		"rollup-plugin-material-all": "^1.2.2",
		"rollup-plugin-minify-template-literals": "^1.1.7",
		"snar": "^2.3.7",
		"snar-save-to-local-storage": "^1.0.1",
		"tailwindcss": "^4.3.0",
		"toastit": "^2.2.2",
		"typescript": "^6.0.3",
		"vite": "^8.0.12",
		"vite-plugin-mdicon2svg": "^0.2.3",
		"vscode-ui-connector": "^0.2.4",
		"wireit": "^0.14.12"
	}
}
