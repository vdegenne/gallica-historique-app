{
	"manifest_version": 3,
	"name": "gallica-historique-app",
	"version": "0.1",
	"host_permissions": ["https://gallica.bnf.fr/ark:/*"],
	"content_scripts": [
		{
			"matches": ["https://gallica.bnf.fr/ark:/*"],
			"js": ["./content.js"],
			"run_at": "document_idle",
			"all_frames": false,
			"world": "MAIN"
		}
	]
}
